# URL pública da API (usada pelo cliente no browser — não necessária, só para referência)
NEXT_PUBLIC_API_URL=https://api.leadmappro.com.br

# URL interna da API no Docker (server-side only — proxy BFF usa esta)
API_URL=http://leadmappro-api:3333

# URL do app (para links absolutos em emails, etc.)
NEXT_PUBLIC_APP_URL=https://app.leadmappro.com.br

# Meta App (para Meta Login / OAuth)
NEXT_PUBLIC_META_APP_ID=1169529831781773
NEXT_PUBLIC_META_CONFIG_ID=952174500513881
